<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILSHAN MARINE GPS</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="hazard-alert" class="whitebar" style="display:none;"></div>

<div id="home" class="tab-pane active">
    <div class="logo-container" style="display: flex; justify-content: center; align-items: center; padding: 20px;">
        <div class="logo-circle" style="width: 80px; height: 80px; border-radius: 50%; border: 3px solid #64ffda; overflow: hidden; animation: rotate 10s linear infinite;">
            <img src="DILGPS.png" class="main-logo" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
    </div>
    <h2 class="app-title" style="text-align: center; color: #64ffda; margin-top: -10px; margin-bottom: 20px;">DILSHAN MARINE GPS</h2>
    
    <div class="card animate-card">
        <div class="label">📍 LOCATION & TIME</div>
        <div class="huge-text" id="lat" style="font-size:35px;">--</div>
        <div class="huge-text" id="lon" style="font-size:35px;">--</div>
        <div class="time-text" id="time" style="font-size:28px; color:#fbc02d; margin-top:10px;">--:--:--</div>
    </div>
    ...
</div>
        <div class="card animate-card">
            <div class="label">🚀 SPEED (SOG)</div>
            <div class="speed-text" id="speed">0.0 km/h</div>
        </div>

        <div class="card animate-card">
            <div class="label">🌬️ WIND INFO</div>
            <div class="wind-text" id="wind-speed">--</div>
            <div class="wind-dir" id="wind-dir">--</div>
        </div>
    </div>

    <div id="windy" class="tab-pane">
        <iframe src="https://embed.windy.com/embed2.html?lat=7.0&lon=80.0&zoom=7" width="100%" height="100%" frameborder="0"></iframe>
    </div>
    
    <div id="mark" class="tab-pane">
        <div class="card animate-card">
            <h3>📍 ගලක් මාක් කරන්න</h3>
            <input type="text" id="h-name" placeholder="ගලේ නම" class="input-field">
            <button class="btn" onclick="saveHazard()">💾 සේව් කරන්න</button>
        </div>
    </div>

    <div id="settings" class="tab-pane">
    <div class="card animate-card">
        <div class="settings-header">
            <img src="DILGPS.png" class="about-logo" style="width:100px; height:100px; border-radius:50%; margin:10px auto; display:block;">
            <h3>DILSHAN MARINE GPS</h3>
            <p style="font-size: 0.9em; opacity: 0.8;">Version: 1.0.0</p>
            <p style="font-weight: bold;">Developer: Sudarshana DILSHAN</p>
            <p>📞 0765529447</p>
        </div>

        <hr style="border: 0; border-top: 1px solid #64ffda; margin: 20px 0;">

        <div class="settings-actions">
            <button class="btn" onclick="toggleTheme()">🌓 DARK / LIGHT MODE</button>
            <button class="btn" onclick="openAdmin()" style="background:#d32f2f;">🛠️ ADMIN PANEL</button>
        </div>

        <div class="settings-support" style="margin-top: 20px;">
            <a href="https://wa.me/94765529447" class="btn" style="background:#25D366; text-decoration:none; display:block;">💬 WHATSAPP SUPPORT</a>
            <a href="#" class="btn" style="background:#1976d2; text-decoration:none; display:block;">⬇️ DOWNLOAD APP</a>
        </div>

        <div id="admin-modal" class="card" style="display:none; border:2px solid red; margin-top:20px;">
            <h4>🛠️ ADMIN CONTROL</h4>
            <input type="text" id="admin-name" placeholder="ගලේ නම" class="input-field" style="width:85%;"><br>
            <input type="number" id="admin-lat" placeholder="Latitude" class="input-field" style="width:85%;"><br>
            <input type="number" id="admin-lon" placeholder="Longitude" class="input-field" style="width:85%;"><br>
            <button class="btn" onclick="adminSaveHazard()">UPLOAD TO MAP</button>
        </div>
    </div>
</div>


    <nav class="bottom-nav">
        <button onclick="showTab('home')">🏠</button>
        <button onclick="showTab('windy')">🌪️</button>
        <button onclick="showTab('mark')">📍+</button>
        <button onclick="showTab('settings')">⚙️</button>
    </nav>
    <script type="module" src="script.js"></script>
</body>
</html>
