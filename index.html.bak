<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILSHAN MARINE GPS</title>
    <link rel="stylesheet" href="style.css">
</head>
<body class="dark-mode">

    <div id="home" class="tab-pane active">
        <div id="hazard-alert" class="whitebar" style="display:none;"></div>
        <div class="logo-container"><img src="DILGPS.png" class="main-logo"></div>
        <div class="main-container">
            <div class="card">
                <div class="label">📍 LOCATION (DMS)</div>
                <div class="huge-text" id="lat">--</div>
                <div class="huge-text" id="lon">--</div>
                <div class="time-text" id="time">--:--:--</div>
            </div>
            <div class="card">
                <div class="label">🚀 SPEED (SOG)</div>
                <div class="huge-text" id="speed">0.0 km/h</div>
            </div>
            <div class="card">
                <div class="label">🌬️ WIND SPEED & DIR</div>
                <div class="huge-text" id="wind-speed">-- km/h</div>
                <div id="wind-dir" style="color:#ffffff; font-size:25px; font-weight:bold;">--</div>
            </div>
        </div>
    </div>

    <div id="windy" class="tab-pane"><iframe src="https://embed.windy.com/embed2.html?lat=7.0&lon=80.0&zoom=7"></iframe></div>

    <div id="mark" class="tab-pane">
        <div class="card">
            <h3>📍 මාක් කරන්න</h3>
            <input type="text" id="h-name" placeholder="ගලේ නම" style="width:80%; padding:10px; border-radius:10px;">
            <button class="btn" onclick="saveHazard()">💾 සේව් කරන්න</button>
        </div>
    </div>

    <div id="settings" class="tab-pane">
        <div class="card">
            <img src="DILGPS.png" class="about-logo">
            <h2>DILSHAN MARINE GPS</h2>
            <a href="https://wa.me/94765529447" class="btn-wa">💬 CONTACT WHATSAPP</a>
            <a href="YOUR_DOWNLOAD_LINK_HERE" class="btn-dl">⬇️ DOWNLOAD APP</a>
        </div>
    </div>

    <nav class="bottom-nav">
        <button onclick="showTab('home')">🏠</button>
        <button onclick="showTab('windy')">🌪️</button>
        <button onclick="showTab('mark')">📍+</button>
        <button onclick="showTab('settings')">⚙️</button>
    </nav>
    <script src="script.js"></script>
</body>
</html>
