<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILSHAN_GPS</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="app-container">
        <header class="app-title">DILSHAN_GPS</header>

        <div class="wind-info">
            සුළඟ: <span id="wind-dir">--</span> | <span id="wind-speed">0</span> km/h
        </div>
        
        <div class="card">
            <div class="label">SPEED (SOG) km/h</div>
            <div class="value" id="speed">0.0</div>
        </div>

        <div class="card">
            <div class="label">COURSE (COG) °</div>
            <div class="value" id="course">---</div>
        </div>

        <div class="card location-card">
            <div class="label">LOCATION / TIME</div>
            <div class="value-loc" id="lat">---</div>
            <div class="value-loc" id="lon">---</div>
            <div class="time" id="time">--:--:--</div>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
