<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILSHAN_GPS</title>
    <link rel="stylesheet" href="style.css?v=7.0">
</head>
<body>
    <div class="app-container">
        <header class="app-title">DILSHAN MARINE GPS</header>
        
        <div class="card wind-card">
            <div class="label">සුළඟ (Wind)</div>
            <div class="value"><span id="wind-dir">--</span> | <span id="wind-speed">0</span> km/h</div>
        </div>

        <div class="card speed-card">
            <div class="label">SPEED (SOG) km/h</div>
            <div class="value huge" id="speed">0.0</div>
        </div>

        <div class="card cog-card">
            <div class="label">COURSE (COG) °</div>
            <div class="value huge" id="course">---</div>
        </div>

        <div class="card location-card">
            <div class="label">LOCATION / TIME</div>
            <div class="value-loc" id="lat">0°00.000' N</div>
            <div class="value-loc" id="lon">0°00.000' E</div>
            <div class="time" id="time">--:--:--</div>
        </div>
    </div>
    <script src="script.js?v=7.0"></script>
</body>
</html>
