<div class="dashboard">
<div class="header-container">
    <div id="compass">
        <!-- මෙහි මාලිමා රූපය හෝ Canvas එකක් තිබිය යුතුය -->
        <p>Wind Direction: <span id="wind-dir">NE</span></p>
    </div>
</div>
  <div class="speed-section">
    <h1>Speed (SOG)</h1>
    <div class="display">0.0</div>
  </div>
  <div class="course-section">
    <h1>Course (COG)</h1>
    <div class="display">---</div>
  </div>
  <div class="location-section">
    <h1>Location/Time</h1>
    <div id="coords">Loading...</div>
    <div id="time"></div>
  </div>
</div>
<!DOCTYPE html>
<html lang="si">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>𝘿𝙄𝙇𝙎𝙃𝘼𝙉_𝙂𝙋𝙎_𝙒𝙀𝘽</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="dashboard">
        <div class="speed-section">
            <h1>Speed (SOG) km/h</h1>
            <div id="speed" class="display">0.0</div>
        </div>
        <div class="course-section">
            <h1>Course (COG) °</h1>
            <div id="course" class="display">---</div>
        </div>
        <div class="location-section">
            <h1>Location/Time</h1>
            <div id="coords">Loading...</div>
            <div id="time"></div>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
