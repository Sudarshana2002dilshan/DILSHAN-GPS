<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DILSHAN MARINE GPS</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="home" class="tab-pane active">
        <div class="logo-container">
            <img src="DILGPS.png" class="main-logo">
        </div>
        <div class="main-container">
            <div class="card">
                <div class="label">LOCATION</div>
                <div class="huge-bold" id="lat">--</div>
                <div class="huge-bold" id="lon">--</div>
                <div class="time-data" id="time">--:--:--</div>
            </div>
            <div class="card">
                <div class="label">SPEED (SOG)</div>
                <div class="huge-data" id="speed">0.0 km/h</div>
            </div>
            <div class="card">
                <div class="label">WIND SPEED</div>
                <div class="huge-data" id="wind-speed">-- km/h</div>
                            <div class="med-data" id="wind-dir">--</div>
            </div>
        </div>
    </div>

    <div id="windy" class="tab-pane"><iframe src="https://embed.windy.com/embed2.html?lat=7.0&lon=80.0&zoom=7"></iframe></div>

        <div id="settings" class="tab-pane">
        <div class="card settings-card">
            <img src="DILGPS.png" width="100">
            <h3>DILSHAN MARINE PRO</h3>
            <button class="theme-btn" onclick="toggleTheme()">DARK / LIGHT MODE</button>
            <div class="contact-box">
                <p>Developer: Sudarshana Dilshan</p>
                <a href="https://wa.me/94765529447" class="wa-btn">CONTACT WHATSAPP</a>
            </div>
        </div>
    </div>

    <nav class="bottom-nav">
        <button onclick="showTab('home')">HOME</button>
        <button onclick="showTab('windy')">WINDY</button>
        <button onclick="showTab('settings')">SET</button>
    </nav>
    <script src="script.js"></script>
</body>
</html>
