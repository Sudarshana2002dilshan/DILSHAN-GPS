<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILSHAN MARINE GPS</title>
    <link rel="stylesheet" href="style.css">
    <link rel="manifest" href="manifest.json">
</head>
<body>
    <header>
        <span>DILSHAN MARINE GPS</span>
        <button onclick="document.getElementById('settingsMenu').classList.toggle('show')">⋮</button>
    </header>

    <div id="settingsMenu" class="settings-panel">
        <img src="https://raw.githubusercontent.com/Sudarshana2002dilshan/Whatsapp-/refs/heads/main/cc327b9e-fab7-4fd9-8f22-3423d0fccef6.png?token=GHSAT0AAAAAAEA3CEBAPJKREQ7ZRIFYPQ6C2SLLMWQ" width="80" style="border-radius:50%">
        <h3>DILSHAN MARINE GPS</h3>
        <button onclick="toggleTheme()">Dark / Light Mode</button>
        <button onclick="toggleBatteryMode()">Battery Optimizer: <span id="bat-status">OFF</span></button>
        <div class="about">
            <p>Developer: Dilshan</p>
            <a href="tel:+94765529447">+94 76 552 9447</a>
        </div>
    </div>

    <div class="dashboard">
        <div class="compass-box">
            <div id="compass-needle" class="needle">▲</div>
        </div>
        <div class="main-data">
            <div class="val-xl" id="speed">0.0 km/h</div>
            <div class="label">Heading: <span id="heading">0°</span></div>
        </div>
        <div class="grid">
            <div class="card">Lat: <span id="lat">0.00000</span></div>
            <div class="card">Lon: <span id="lon">0.00000</span></div>
            <div class="card">Wind: <span id="wind">--</span></div>
            <div class="card">Time: <span id="time">00:00</span></div>
        </div>
    </div>

    <nav class="bottom-nav">
        <button onclick="saveWaypoint()">+ POINT</button>
        <button class="sos-btn" onclick="sendSOS()">SOS</button>
    </nav>
    <script src="script.js"></script>
</body>
</html>
