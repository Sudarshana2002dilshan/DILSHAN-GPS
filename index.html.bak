<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILSHAN MARINE GPS</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div id="home" class="tab-pane active">
        <header class="app-header">
            <img src="DILGPS.png" alt="Logo" class="logo">
            <h2 class="app-name">DILSHAN MARINE GPS</h2>
        </header>

        <div class="card">
            <div class="label">සුළඟ (Wind)</div>
            <div class="card-content">
                <div class="info-row">වේගය: <b id="wind-speed">--</b> km/h</div>
                <div class="info-row">දිශාව: <b id="wind-dir">--</b></div>
            </div>
        </div>

        <div class="card">
            <div class="label">SPEED (SOG)</div>
            <div class="huge-val" id="speed">0.0</div>
        </div>

        <div class="card">
            <div class="label">LOCATION / TIME</div>
            <div class="loc-val" id="lat">0.0000 N</div>
            <div class="loc-val" id="lon">0.0000 E</div>
            <div class="time-val" id="time">--:--:--</div>
        </div>
    </div>

    <div id="windy" class="tab-pane">
        <iframe src="https://embed.windy.com/embed2.html?lat=7.0&lon=80.0&zoom=7" width="100%" height="90vh"></iframe>
    </div>

    <div id="settings" class="tab-pane">
        <div class="card settings-card">
            <img src="DILGPS.png" width="80">
            <h3>DILSHAN MARINE PRO</h3>
            <button class="theme-btn" onclick="toggleTheme()">DARK / LIGHT MODE</button>
            <div class="dev-section">
                <h4>HELP & CONTACT</h4>
                <p>Developer: Sudarshana Dilshan</p>
                <p>Phone: 0765529447</p>
                <a href="https://wa.me/94765529447" class="wa-btn">CONTACT WHATSAPP</a>
            </div>
        </div>
    </div>

    <nav class="bottom-nav">
        <button onclick="showTab('home')">🏠 HOME</button>
        <button onclick="showTab('windy')">🌪️ WINDY</button>
        <button onclick="showTab('settings')">⚙️ SETTINGS</button>
    </nav>

    <script src="script.js"></script>
</body>
</html>
