<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILSHAN MARINE GPS</title>
    <link rel="stylesheet" href="style.css">
    <link rel="manifest" href="manifest.json">
</head>
<body>
    <div id="home" class="tab-pane active">
        <header class="app-header">
            <img src="DILGPS.png" class="logo">
            <h1 class="app-title">DILSHAN MARINE GPS</h1>
        </header>

        <div class="card">
            <div class="label">සුළඟ (WIND)</div>
            <div class="large-data" id="wind-speed">-- km/h</div>
            <div class="med-data" id="wind-dir">--</div>
        </div>

        <div class="card">
            <div class="label">SPEED (SOG)</div>
            <div class="huge-data" id="speed">0.0 km/h</div>
        </div>

        <div class="card">
            <div class="label">LOCATION / TIME</div>
            <div class="huge-loc" id="lat">0°00.000' N</div>
            <div class="huge-loc" id="lon">0°00.000' E</div>
            <div class="time-data" id="time">--:--:--</div>
        </div>
    </div>

    <div id="windy" class="tab-pane">
        <iframe src="https://embed.windy.com/embed2.html?lat=7.0&lon=80.0&zoom=7" class="full-screen-map"></iframe>
    </div>

    <div id="settings" class="tab-pane">
        <div class="card settings-card">
            <img src="DILGPS.png" width="100">
            <h3>DILSHAN MARINE PRO</h3>
            <button class="theme-btn" onclick="toggleTheme()">DARK / LIGHT MODE</button>
            <div class="contact-box">
                <p>Developer: Sudarshana Dilshan</p>
                <a href="https://wa.me/94765529447" class="wa-btn">CONTACT WHATSAPP</a>
            </div>
        </div>
    </div>

    <nav class="bottom-nav">
        <button onclick="showTab('home')">🏠 HOME</button>
        <button onclick="showTab('windy')">🌪️ WINDY</button>
        <button onclick="showTab('settings')">⚙️ SETTINGS</button>
    </nav>
    <script src="script.js"></script>
</body>
</html>
