<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>DILSHAN_GPS</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header class="app-title">DILSHAN_GPS</header>
    <div class="wind-bar">Wind: <span id="windSpeed">--</span> km/h | Dir: <span id="windDir">--</span>°</div>

    <div class="tabs">
        <button onclick="showTab('main')">Live</button>
        <button onclick="showTab('map')">Map</button>
        <button onclick="showTab('stats')">Stats</button>
    </div>

    <div id="main" class="tab-content">
        <div class="card"><div class="label">SPEED (km/h)</div><div class="value" id="speed">0.0</div></div>
        <div class="card location-card"><div class="value-loc" id="lat">---</div><div class="value-loc" id="lon">---</div></div>
        <button class="save-btn" onclick="saveWaypoint()">SAVE WAYPOINT</button>
    </div>

    <div id="map" class="tab-content" style="display:none">
        <div id="mapView" class="card" style="height:300px">Map View Active</div>
    </div>

    <script src="script.js"></script>
</body>
</html>
