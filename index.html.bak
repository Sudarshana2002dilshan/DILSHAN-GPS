<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MARINE GPS</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="tabs">
        <button onclick="showTab('home')">LIVE</button>
        <button onclick="showTab('points')">POINTS</button>
        <button onclick="showTab('settings')">SOS</button>
    </div>

    <div id="home" class="tab-content">
        <div class="main-val" id="speed">0.0 km/h</div>
        <div class="loc-box">
            <div class="val-big" id="lat">0.00000</div>
            <div class="val-big" id="lon">0.00000</div>
        </div>
        <div class="sub-box">
            <div id="time">--:--:--</div>
            <div id="wind">--</div>
        </div>
    </div>

    <div id="points" class="tab-content" style="display:none">
        <button class="action-btn" onclick="addWaypoint()">+ SAVE POSITION</button>
        <ul id="wp-list"></ul>
    </div>

    <div id="settings" class="tab-content" style="display:none">
        <button class="sos-btn" onclick="sendSOS()">SOS EMERGENCY</button>
    </div>

    <script src="script.js"></script>
</body>
</html>
