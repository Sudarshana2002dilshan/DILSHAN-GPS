<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILSHAN MARINE GPS</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="hazard-alert" class="whitebar" style="display:none; background: #ff1744; color: white; text-align: center; padding: 12px; font-weight: bold; font-size: 16px; position: fixed; top: 0; width: 100%; z-index: 9999;"></div>

    <div id="home" class="tab-pane active" style="margin-top: 50px; padding-bottom: 80px;">
        <div class="logo-container" style="display: flex; justify-content: center; align-items: center; padding: 20px;">
            <div class="logo-circle" style="width: 80px; height: 80px; border-radius: 50%; border: 3px solid #64ffda; overflow: hidden; animation: rotate 10s linear infinite;">
                <img src="DILGPS.png" class="main-logo" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
        </div>
        <h2 class="app-title" style="text-align: center; color: #64ffda;">DILSHAN MARINE GPS</h2>
        
        <div class="card animate-card">
            <div class="label">📍 LOCATION & TIME</div>
            <div class="huge-text" id="lat" style="font-size: 2rem; font-weight: bold; text-align: center; margin: 10px 0;">--</div>
            <div class="huge-text" id="lon" style="font-size: 2rem; font-weight: bold; text-align: center; margin: 10px 0;">--</div>
            <div class="time-text" id="time" style="text-align: center; opacity: 0.7;">--:--:--</div>
        </div>

        <div class="card animate-card">
            <div class="label">🚀 SPEED (SOG)</div>
            <div class="speed-text" id="speed" style="font-size: 3rem; font-weight: bold; text-align: center; color: #ff5722;">0.0 km/h</div>
        </div>

        <div class="card animate-card">
            <div class="label">🌬️ WIND INFO & 🌊 CURRENT</div>
            <div class="wind-text" id="wind-speed" style="text-align: center;">--</div>
            <div class="wind-dir" id="wind-dir" style="text-align: center;">--</div>
            
            <hr style="border: 0; border-top: 1px solid rgba(100, 255, 218, 0.3); margin: 15px 0;">
            <div class="label" style="color: #00e676;">🌊 OCEAN CURRENT (දියකඩ)</div>
            <div class="current-text" id="current-speed" style="text-align: center;">-- m/s</div>
            <div class="current-dir" id="current-dir" style="text-align: center;">--</div>
        </div>
    </div>

    <div id="windy" class="tab-pane" style="display:none; height: 100vh; padding-bottom: 80px;">
        <iframe src="https://embed.windy.com/embed2.html?lat=7.0&lon=80.0&zoom=7&level=surface&overlay=currents&menu=&message=&marker=&calendar=&pressure=&type=map&location=coordinates&detail=&metricWind=default&metricTemp=default&radarRange=-1" width="100%" height="100%" frameborder="0"></iframe>
    </div>
    
    <div id="mark" class="tab-pane" style="display:none; padding: 20px; padding-bottom: 80px;">
        <div class="card animate-card">
            <h3>📍 ගලක් මාක් කරන්න</h3>
            <input type="text" id="h-name" placeholder="ගලේ නම" class="input-field" style="width: 100%; padding: 10px; margin: 10px 0; border-radius: 8px;">
            <button class="btn" onclick="saveHazard()" style="width: 100%; padding: 12px; background: #64ffda; color: black; font-weight: bold; border: none; border-radius: 8px;">💾 සේව් කරන්න</button>
        </div>
    </div>

    <div id="settings" class="tab-pane" style="display:none; padding: 20px; padding-bottom: 80px;">
        <div class="card animate-card">
            <div class="settings-header" style="text-align: center;">
                <img src="DILGPS.png" style="width:100px; height:100px; border-radius:50%; margin:10px auto; display:block; border: 2px solid #64ffda;">
                <h3>DILSHAN MARINE GPS</h3>
                <p style="font-size: 0.9em; opacity: 0.8;">Version: 1.0.0</p>
                <p style="font-weight: bold;">Developer: Sudarshana DILSHAN</p>
                <p>📞 0765529447</p>
            </div>

            <hr style="border: 0; border-top: 1px solid #64ffda; margin: 20px 0;">

            <div class="settings-actions">
                <button class="btn" onclick="toggleTheme()" style="width: 100%; padding: 10px; margin: 5px 0;">🌓 DARK / LIGHT MODE</button>
                <button class="btn" onclick="toggleNightVision()" style="width: 100%; padding: 10px; margin: 5px 0; background:#ff1744; color:white;">🌙 NIGHT VISION MODE (🔴)</button>
                <button class="btn" onclick="showBatteryInfo()" style="width: 100%; padding: 10px; margin: 5px 0; background:#ff9800; color:black;">🔋 BATTERY OPTIMIZATION</button>
                <button class="btn" onclick="openAdmin()" style="width: 100%; padding: 10px; margin: 5px 0; background:#d32f2f; color: white;">🛠️ ADMIN PANEL</button>
                <a href="https://wa.me/94765529447" class="btn" style="background:#25D366; text-decoration:none; display:block; text-align: center; padding: 10px; margin: 5px 0; color: white; border-radius: 8px;">💬 WHATSAPP SUPPORT</a>
                <a href="https://drive.google.com/uc?export=download&id=1rCkE_Xmfg0xJFFbBvRW5ETSVuGBFw11l" class="btn" style="background:#1976d2; text-decoration:none; display:block; text-align: center; padding: 10px; margin: 5px 0; color: white; border-radius: 8px;">⬇️ DOWNLOAD APP</a>
            </div>

            <hr style="border: 0; border-top: 1px solid #64ffda; margin: 20px 0;">

            <div style="background: rgba(100, 255, 218, 0.05); padding: 15px; border-radius: 15px; border: 1px solid #64ffda; text-align: left;">
                <h4 style="color: #64ffda; margin-top: 0; text-align: center;">🔄 GPS COORDINATES CONVERTER</h4>
                <p style="font-size: 13px; opacity: 0.8; text-align: center;">වෙනත් අය දෙන GPS අංක ඇප් එකේ ක්‍රමයට (DMS) හරවා ගන්න.</p>
                
                <label style="font-size: 12px; font-weight: bold;">Decimal Format (උදා: 7.12345):</label>
                <input type="number" id="convert-input" placeholder="7.12345" class="input-field" style="width:100%; padding: 10px; margin: 5px 0; border-radius: 8px;">
                
                <button class="btn" onclick="convertGPS()" style="width:100%; padding: 10px; margin: 10px 0; background: #64ffda; color: black;">🔄 CONVERT (හරවන්න)</button>
                
                <div style="font-weight: bold; font-size: 16px; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 8px; border-left: 5px solid #ff9800; color: white;">
                    ප්‍රතිඵලය (DMS): <span id="convert-result" style="color: #ff5722;">--</span>
                </div>
            </div>

            <div id="admin-modal" class="card" style="display:none; border:2px solid red; margin-top:20px; padding: 15px;">
                <h4>🛠️ ADMIN CONTROL</h4>
                <input type="text" id="admin-name" placeholder="ගලේ නම" class="input-field" style="width:100%; padding: 8px; margin: 5px 0;"><br>
                <input type="number" id="admin-lat" placeholder="Latitude (Decimal)" class="input-field" style="width:100%; padding: 8px; margin: 5px 0;"><br>
                <input type="number" id="admin-lon" placeholder="Longitude (Decimal)" class="input-field" style="width:100%; padding: 8px; margin: 5px 0;"><br>
                <button class="btn" onclick="adminSaveHazard()" style="width: 100%; background: red; color: white; padding: 10px;">UPLOAD TO MAP</button>
            </div>
        </div>
    </div>

    <nav class="bottom-nav" style="position: fixed; bottom: 0; width: 100%; display: flex; justify-content: space-around; background: #0a192f; padding: 15px 0; border-top: 1px solid #64ffda; z-index: 9999;">
        <button onclick="showTab('home')" style="background: none; border: none; font-size: 24px; cursor: pointer;">🏠</button>
        <button onclick="showTab('windy')" style="background: none; border: none; font-size: 24px; cursor: pointer;">🌪️</button>
        <button onclick="showTab('mark')" style="background: none; border: none; font-size: 24px; cursor: pointer;">📍+</button>
        <button onclick="showTab('settings')" style="background: none; border: none; font-size: 24px; cursor: pointer;">⚙️</button>
    </nav>

    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('./sw.js').then((reg) => {
                console.log("Service Worker Registered!");
                reg.onupdatefound = () => {
                    const installingWorker = reg.installing;
                    installingWorker.onstatechange = () => {
                        if (installingWorker.state === 'installed') {
                            if (navigator.serviceWorker.controller) {
                                window.location.reload();
                            }
                        }
                    };
                };
            }).catch(err => console.log("Service Worker Failed: ", err));
        }
    </script>
    <script type="module" src="script.js"></script>
</body>
</html>
