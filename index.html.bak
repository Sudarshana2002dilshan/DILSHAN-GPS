<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>DILSHAN MARINE GPS</title>
    <link rel="stylesheet" href="style.css?v=5.0">
</head>
<body>
    <div id="sidebar" class="sidebar">
        <div class="sidebar-header">
            <img src="https://raw.githubusercontent.com/Sudarshana2002dilshan/Whatsapp-/refs/heads/main/cc327b9e-fab7-4fd9-8f22-3423d0fccef6.png?token=GHSAT0AAAAAAEA3CEBAPJKREQ7ZRIFYPQ6C2SLLMWQ" width="60" style="border-radius:50%">
            <h3>DILSHAN MARINE</h3>
        </div>
        <button onclick="showTab('home')">GPS Info</button>
        <button onclick="showTab('windy-tab')">Windy Forecast</button>
        <button onclick="toggleTheme()">Dark / Light Mode</button>
    </div>

    <header>
        <button onclick="toggleSidebar()">☰</button>
        <span>DILSHAN MARINE GPS</span>
    </header>

    <div id="home" class="tab-pane active">
        <div class="wind-box">
            සුළඟ: <span id="wind-dir">--</span> | <span id="wind-speed">0</span> km/h
        </div>
        <div class="compass-wrapper">
            <div id="compass-needle" class="compass-needle">▲</div>
        </div>
        <div class="box"><div class="label-text">SPEED (km/h)</div><div id="speed" class="big-num">0.0</div></div>
        <div class="box">
            <div class="label-text">LOCATION / TIME</div>
            <div id="lat" class="data-val">0.0000 N</div>
            <div id="lon" class="data-val">0.0000 E</div>
            <div id="time" class="data-val" style="color:#004d40;">00:00:00</div>
        </div>
    </div>

    <div id="windy-tab" class="tab-pane">
        <h3 style="text-align:center;">Weather Forecast</h3>
        <div id="forecast-data"></div>
    </div>

    <nav class="bottom-nav">
        <button class="sos-btn" onclick="sendSOS()">SOS</button>
        <button onclick="saveWaypoint()">+ WAYPOINT</button>
    </nav>
    <script src="script.js?v=5.0"></script>
</body>
</html>
