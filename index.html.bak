<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILSHAN MARINE GPS</title>
    <link rel="stylesheet" href="style.css?v=3.0">
    <link rel="manifest" href="manifest.json">
</head>
<body>
    <header>
        <span>DILSHAN MARINE GPS</span>
        <button onclick="document.getElementById('settingsMenu').classList.toggle('show')">⋮</button>
    </header>

    <div id="settingsMenu" class="settings-panel">
        <div style="text-align: center;">
            <img src="https://raw.githubusercontent.com/Sudarshana2002dilshan/Whatsapp-/refs/heads/main/cc327b9e-fab7-4fd9-8f22-3423d0fccef6.png?token=GHSAT0AAAAAAEA3CEBAPJKREQ7ZRIFYPQ6C2SLLMWQ" width="80" style="border-radius:50%; border:2px solid #38bdf8;">
            <h3>DILSHAN MARINE GPS</h3>
        </div>
        <button class="menu-btn" onclick="toggleTheme()">Dark / Light Mode</button>
        <button class="menu-btn" onclick="toggleBatteryMode()">Battery Optimizer: <span id="bat-status">OFF</span></button>
        <hr style="border: 0.5px solid #333; margin: 20px 0;">
        <div class="about">
            <p style="color:#aaa;">Developed by: <strong>Dilshan</strong></p>
            <p>Call/WhatsApp:</p>
            <a href="tel:+94765529447" class="contact-link">+94 76 552 9447</a>
        </div>
    </div>

    <div id="home" class="tab-pane active">
        <div class="compass-box">
            <div id="compass-needle" class="needle">▲</div>
        </div>
        <div class="val-xl" id="speed">0.0 km/h</div>
        <div class="grid">
            <div class="card">Lat<br><span id="lat" class="data-val">0.00000</span></div>
            <div class="card">Lon<br><span id="lon" class="data-val">0.00000</span></div>
            <div class="card">Heading<br><span id="heading" class="data-val">0°</span></div>
            <div class="card">Time<br><span id="time" class="data-val">00:00</span></div>
        </div>
    </div>

    <div id="windy-tab" class="tab-pane">
        <h3 style="text-align:center; color:#38bdf8; margin-bottom: 20px;">කාලගුණ අනාවැකිය</h3>
        <div id="forecast-data">
            <p style="text-align:center;">GPS ස්ථානය ලබා ගනිමින් පවතී...</p>
        </div>
    </div>

    <nav class="bottom-nav">
        <button onclick="showTab('home')">HOME</button>
        <button onclick="showTab('windy-tab'); fetchForecast();">WINDY</button>
        <button onclick="saveWaypoint()">+ POINT</button>
        <button class="sos-btn" onclick="sendSOS()">SOS</button>
    </nav>

    <script src="script.js?v=3.0"></script>
</body>
</html>
