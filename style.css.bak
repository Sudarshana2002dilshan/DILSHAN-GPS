body {
  font-family: Arial, sans-serif;
  background-color: #e0f7fa;
  margin: 0;
  padding: 10px;
}
.header-container {
    background-color: #e0f7fa; /* "149985.jpg" හි ඇති වර්ණයට සමානයි */
    text-align: center;
    padding: 10px;
    border-bottom: 2px solid #003366;
}

#compass {
    font-weight: bold;
    color: #003366;
    margin-bottom: 10px;
}


.dashboard {
  max-width: 400px;
  margin: 0 auto;
}

.speed-section, .course-section, .location-section {
  background-color: #ffffff;
  border: 2px solid #003366;
  border-radius: 12px;
  padding: 15px;
  margin-bottom: 15px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
}

h1 {
  color: #003366;
  font-size: 1.2rem;
  margin: 0 0 10px 0;
  text-align: center;
}

.display {
  font-size: 2.5rem;
  font-weight: bold;
  color: #003366;
  text-align: center;
}

#coords {
  font-size: 1.2rem;
  color: #333;
  text-align: center;
}
