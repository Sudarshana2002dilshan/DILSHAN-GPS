body { background: #e0f7fa; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 10px; }
.app-container { display: flex; flex-direction: column; gap: 12px; }
.app-title { font-size: 24px; font-weight: bold; color: #004d40; text-align: center; margin-bottom: 10px; }

/* කාඩ්පත් ඩිසයින් */
.card { background: white; padding: 15px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); border-left: 6px solid #004d40; animation: fadeIn 0.8s ease-in-out; }
.huge { font-size: 70px; font-weight: 800; color: #004d40; text-align: center; }
.label { font-size: 14px; color: #666; font-weight: bold; text-transform: uppercase; }
.value-loc { font-size: 22px; font-weight: bold; }

/* ඇනිමේෂන් */
@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
