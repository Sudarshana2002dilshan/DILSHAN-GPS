:root {
    /* Default Dark Mode */
    --bg-color: #0a192f;
    --card-bg: #112240;
    --text-color: #ffffff;
    --accent-color: #64ffda;
    --label-color: #8892b0;
}

body.light-mode {
    --bg-color: #f0f2f5;
    --card-bg: #ffffff;
    --text-color: #1a1a1a;
    --accent-color: #004d40;
    --label-color: #555555;
}

body { margin: 0; font-family: sans-serif; background: var(--bg-color); color: var(--text-color); transition: 0.3s; }
.card { background: var(--card-bg); border: 2px solid var(--accent-color); margin: 15px; padding: 25px; border-radius: 25px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
.huge-text { font-size: 40px; font-weight: 900; color: var(--accent-color); margin: 5px 0; }
.label { font-size: 14px; color: var(--label-color); text-transform: uppercase; font-weight: bold; }
.main-logo { width: 120px; height: 120px; border-radius: 50%; border: 4px solid var(--accent-color); margin: 20px; }
.bottom-nav { position: fixed; bottom: 0; width: 100%; display: flex; background: #004d40; border-top: 3px solid var(--accent-color); }
.bottom-nav button { flex: 1; padding: 20px; border: none; background: none; color: white; font-size: 20px; cursor: pointer; }
iframe { width: 100%; height: 100vh; border: none; }
.btn { width: 100%; padding: 15px; background: var(--accent-color); color: var(--bg-color); border-radius: 15px; font-weight: bold; border: none; }
.btn-wa { display: block; padding: 15px; background: #25D366; color: white; border-radius: 15px; margin-top: 15px; text-decoration: none; font-weight: bold; text-align: center; }
