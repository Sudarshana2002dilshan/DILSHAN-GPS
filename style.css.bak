body { background: #000; color: #fff; font-family: sans-serif; margin: 0; transition: 0.3s; }
.light-mode { background: #fff; color: #000; }
header { padding: 15px; background: #111; display: flex; justify-content: space-between; }
.settings-panel { display: none; position: fixed; top: 0; right: 0; width: 250px; height: 100%; background: #1a1a1a; padding: 20px; z-index: 1000; }
.menu-btn { width: 100%; padding: 12px; margin: 5px 0; background: #222; border: 1px solid #444; color: white; border-radius: 5px; cursor: pointer; }
.data-val { font-size: 1.2em; font-weight: bold; color: #fff; }
.contact-link { color: #38bdf8; font-size: 1.2em; font-weight: bold; text-decoration: none; }
.card { background: #111; padding: 15px; border-radius: 12px; border: 1px solid #222; text-align: center; }
.settings-panel.show { display: block; }
.tab-pane { display: none; padding: 20px; }
.active { display: block; }
.compass-box { width: 120px; height: 120px; border: 4px solid #38bdf8; border-radius: 50%; margin: 20px auto; position: relative; }
.needle { position: absolute; top: 10px; left: 60px; color: #fbbf24; transition: transform 0.3s; }
.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.card { background: #111; padding: 10px; border-radius: 8px; text-align: center; }
.val-xl { font-size: 40px; font-weight: bold; text-align: center; color: #38bdf8; margin: 10px; }
.bottom-nav { position: fixed; bottom: 0; width: 100%; display: flex; background: #111; }
.bottom-nav button { flex: 1; padding: 15px; border: none; background: #222; color: #fff; }
.sos-btn { background: #dc2626 !important; }
