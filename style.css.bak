body { margin: 0; font-family: sans-serif; background: #0a192f; color: #fff; min-height: 100vh; padding-bottom: 80px; }
.tab-pane { display: none; }
.active { display: block; }
.logo-container { text-align: center; padding: 20px; }
.main-logo { width: 80px; height: 80px; border-radius: 50%; border: 2px solid #64ffda; }
.card { background: #112240; margin: 10px; padding: 20px; border-radius: 15px; text-align: center; box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
.huge-data { font-size: 40px; font-weight: 900; color: #64ffda; }
.huge-bold { font-size: 30px; font-weight: 900; color: #fff; }
.time-data { font-size: 30px; font-weight: 800; color: #fbc02d; margin-top: 10px; }
.dir-text { font-size: 20px; font-weight: bold; color: #fff; margin-top: 5px; }
.label { font-size: 13px; color: #8892b0; text-transform: uppercase; margin-bottom: 5px; }
.bottom-nav { position: fixed; bottom: 0; width: 100%; display: flex; background: #0a192f; border-top: 2px solid #64ffda; }
.bottom-nav button { flex: 1; padding: 15px; border: none; background: none; color: #64ffda; font-weight: bold; cursor: pointer; }
.btn { width: 100%; padding: 12px; background: #004d40; color: white; border-radius: 10px; border: none; margin-top: 10px; }
.btn-wa { display: block; padding: 12px; background: #25D366; color: white; text-decoration: none; border-radius: 10px; margin-top: 10px; text-align: center; font-weight: bold; }
iframe { width: 100%; height: 80vh; border: none; }
