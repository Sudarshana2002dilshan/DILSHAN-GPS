body {
    margin: 0;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background-color: #060d1a;
    color: #edf2f7;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    overflow-x: hidden;
}

.fade-in {
    animation: fadeIn 0.6s ease-out forwards;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
}

.alert-bar {
    display: none;
    background: linear-gradient(90deg, #ff1744, #b71c1c);
    color: white;
    text-align: center;
    padding: 14px;
    font-weight: bold;
    font-size: 22px;
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 9999;
    box-shadow: 0 4px 15px rgba(255,23,68,0.4);
}

.tab-pane {
    display: none;
    margin-top: 15px;
    padding: 0 10px 110px 10px;
    box-sizing: border-box;
}

.tab-pane.active {
    display: block;
}

.logo-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
}

.logo-circle {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    overflow: hidden;
}

.glow-blue { border: 3px solid #64ffda; box-shadow: 0 0 20px rgba(100, 255, 218, 0.4); }
.main-logo { width: 100%; height: 100%; object-fit: cover; }

.app-title {
    text-align: center;
    color: #64ffda;
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 20px 0;
}

/* --- CARDS DESIGN --- */
.card {
    background: rgba(23, 42, 69, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 20px;
    padding: 24px;
    margin: 15px 5px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.location-card { border: 2px solid #64ffda; }
.speed-card { border: 2px solid #ff5722; }
.marine-card { border: 2px solid #00e676; }
.admin-card { border: 2px solid #ff1744; }

.label {
    text-align: center;
    font-size: 15px;
    font-weight: 700;
    color: #64ffda;
    letter-spacing: 1.5px;
}

.huge-text {
    font-size: 3.8rem;
    font-weight: 900;
    text-align: center;
    color: #ffffff;
    margin: 10px 0;
    font-family: 'Courier New', Courier, monospace;
}

.speed-text {
    font-size: 5.2rem;
    font-weight: 900;
    text-align: center;
    color: #ff5722;
    margin: 5px 0;
}

.marine-text {
    text-align: center;
    font-size: 3.8rem;
    font-weight: 900;
    color: #00e676;
    margin: 5px 0;
}

.marine-sub { text-align: center; font-size: 22px; font-weight: bold; color: #edf2f7; }
.time-text { text-align: center; font-size: 26px; font-weight: bold; color: #ff9800; margin-top: 10px; }
.card-hr { border: 0; border-top: 2px solid rgba(100, 255, 218, 0.15); margin: 22px 0; }

/* --- INPUTS & BUTTONS --- */
.input-field {
    width: 100%;
    padding: 16px;
    font-size: 18px;
    margin: 15px 0;
    border-radius: 12px;
    box-sizing: border-box;
    background: #0a192f;
    border: 1px solid rgba(100,255,218,0.3);
    color: white;
}

.btn {
    width: 100%;
    padding: 16px;
    font-size: 18px;
    font-weight: bold;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    box-sizing: border-box;
}

.btn-submit { background: linear-gradient(135deg, #64ffda, #00b0ff); color: #060d1a; }
.btn-action { background: rgba(100, 255, 218, 0.05); border: 1px solid rgba(100, 255, 218, 0.4); color: #64ffda; margin: 8px 0; }
.btn-danger { background: linear-gradient(135deg, #ff1744, #d50000); color: white; }
.btn-warning { background: linear-gradient(135deg, #ff9800, #f57c00); color: black; }

/* --- ADMIN PANEL LIST --- */
.admin-stats {
    background: rgba(100,255,218,0.06);
    padding: 12px;
    border-radius: 8px;
    text-align: center;
    font-size: 16px;
    margin-bottom: 15px;
    border: 1px solid rgba(100,255,218,0.2);
}
.hazard-list-container {
    max-height: 250px;
    overflow-y: auto;
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
    padding: 10px;
}
.hazard-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(23,42,69,0.9);
    padding: 12px;
    margin: 8px 0;
    border-radius: 10px;
    border-left: 4px solid #ff1744;
}
.hazard-info h5 { margin: 0; font-size: 16px; color: white; }
.hazard-info p { margin: 2px 0 0 0; font-size: 12px; opacity: 0.7; font-family: monospace; }
.btn-delete-item { background: #ff1744; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; }

.converter-box { background: rgba(100, 255, 218, 0.02); padding: 15px; border-radius: 15px; border: 1px solid rgba(100, 255, 218, 0.15); }
.result-box { font-weight: bold; font-size: 22px; background: rgba(0,0,0,0.4); padding: 14px; border-radius: 10px; text-align: center; border: 1px solid rgba(255,87,34,0.3); }
.settings-header { text-align: center; }
.settings-logo { width: 95px; height: 95px; border-radius: 50%; }
.dev-text { font-size: 18px; font-weight: bold; color: #64ffda; margin: 5px 0; }
.phone-text { font-size: 18px; font-weight: bold; margin: 5px 0; }

/* --- BOTTOM NAVIGATION --- */
.bottom-nav {
    position: fixed;
    bottom: 0;
    width: 100%;
    display: flex;
    justify-content: space-around;
    background: rgba(10, 25, 47, 0.9);
    backdrop-filter: blur(15px);
    padding: 15px 0;
    border-top: 1px solid rgba(100, 255, 218, 0.3);
    z-index: 9999;
}
.nav-btn { background: none; border: none; font-size: 28px; cursor: pointer; opacity: 0.5; transition: all 0.3s ease; padding: 5px 10px; border-radius: 10px; }
.active-nav { opacity: 1 !important; background: rgba(100, 255, 218, 0.15); color: #64ffda; }

/* 🌓 Light & Night Modes */
.light-mode { background-color: #f4f7f6 !important; color: #1a202c !important; }
.light-mode .card { background: #ffffff !important; color: #1a202c !important; border: 1px solid #e2e8f0 !important; }
.light-mode .huge-text, .light-mode .marine-sub { color: #2d3748 !important; }
.light-mode .input-field { background: #edf2f7 !important; color: black !important; }
.light-mode .bottom-nav { background: rgba(255,255,255,0.9) !important; border-top: 1px solid #cbd5e0 !important; }
.light-mode .hazard-item { background: #edf2f7 !important; }
.light-mode .hazard-info h5 { color: black; }

.night-vision-mode { background-color: #000000 !important; }
.night-vision-mode body, .night-vision-mode .card, .night-vision-mode h2, .night-vision-mode h3, .night-vision-mode .label, .night-vision-mode .huge-text, .night-vision-mode .speed-text, .night-vision-mode .marine-text, .night-vision-mode .marine-sub, .night-vision-mode .time-text, .night-vision-mode .hazard-info h5, .night-vision-mode .admin-stats { background-color: #000000 !important; color: #ff1744 !important; border-color: #ff1744 !important; }
.night-vision-mode .bottom-nav { background: #000000 !important; border-top: 1px solid #ff1744 !important; }
.night-vision-mode .active-nav { background: rgba(255,23,68,0.2) !important; }
.night-vision-mode .hazard-item { background: #000000 !important; border: 1px solid #ff1744 !important; }
