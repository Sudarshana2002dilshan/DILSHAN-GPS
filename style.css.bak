:root { --bg: #0a192f; --card: #112240; --text: #ffffff; --accent: #64ffda; --time: #fbc02d; }
.light-mode { --bg: #f4f4f4; --card: #ffffff; --text: #000000; }
body { background: var(--bg); color: var(--text); font-family: sans-serif; height: 100vh; margin:0; }
.tab-pane { display: none; height: 85vh; overflow-y: auto; padding-bottom: 20px; }
.tab-pane.active { display: block; }
.main-logo { width: 90px; border-radius: 50%; margin: 15px auto; display: block; border: 3px solid var(--accent); }
.card { background: var(--card); margin: 15px; padding: 20px; border-radius: 20px; text-align: center; border: 1px solid var(--accent); }
.huge-text { font-size: 32px; font-weight: 900; }
.time-text { font-size: 28px; color: var(--time); font-weight: bold; margin-top: 10px; }
.speed-text { font-size: 36px; font-weight: 900; color: #ff5722; }
.wind-text { font-size: 28px; font-weight: bold; }
.wind-dir { font-size: 20px; color: var(--accent); }
.bottom-nav { position: fixed; bottom: 0; width: 100%; display: flex; background: #004d40; }
.bottom-nav button { flex: 1; padding: 20px; border:none; background:none; color: white; font-size: 22px; }
.btn { width: 100%; padding: 15px; margin-top:10px; border-radius: 10px; border: none; background: #00796b; color: white; font-weight: bold; }
