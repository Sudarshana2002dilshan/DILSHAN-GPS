body { background: #e0f7fa; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 10px; }
.app-container { display: flex; flex-direction: column; gap: 12px; }
.app-title { font-size: 24px; font-weight: bold; color: #004d40; text-align: center; margin-bottom: 10px; }

/* කාඩ්පත් ඩිසයින් */
.card { background: white; padding: 15px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); animation: fadeIn 0.8s ease-in-out; }

/* Speed සහ Course සඳහා රතු වර්ණය සහ 60px ප්‍රමාණය */
.speed-card, .cog-card { border-left: 6px solid #b71c1c; }
.huge { font-size: 60px; font-weight: 800; color: #b71c1c; text-align: center; }

/* Location සහ Time සඳහා සැකසුම් */
.location-card { border-left: 6px solid #004d40; text-align: center; }
.label { font-size: 14px; color: #666; font-weight: bold; text-transform: uppercase; text-align: center; }
.value-loc { font-size: 28px; font-weight: bold; color: #000; }
.time { font-size: 22px; font-weight: bold; color: #000; margin-top: 5px; }

/* ඇනිමේෂන් */
@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
