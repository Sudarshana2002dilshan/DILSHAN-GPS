body { background-color: #e0f7fa; font-family: sans-serif; display: flex; justify-content: center; padding: 20px; }
.card { background: white; width: 100%; max-width: 400px; padding: 20px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
.header { font-size: 20px; font-weight: bold; color: #003366; text-align: center; margin-bottom: 20px; }
.data-box { border: 2px solid #003366; padding: 15px; margin-bottom: 15px; border-radius: 10px; text-align: center; }
#speed, #course { font-size: 24px; font-weight: bold; color: #d32f2f; }
