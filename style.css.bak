body { background: #f0f4f8; font-family: sans-serif; margin: 0; padding-bottom: 80px; transition: 0.3s; }
.dark-mode { background: #121212; color: #fff; }
.dark-mode .card { background: #1e1e1e; border-left: 6px solid #fbc02d; }
.app-header { display: flex; align-items: center; padding: 10px; background: #004d40; color: white; gap: 15px; }
.logo { width: 60px; }
.card { background: white; margin: 15px; padding: 25px; border-radius: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); border-left: 8px solid #004d40; text-align: center; }
.label { font-weight: 800; text-transform: uppercase; color: #777; margin-bottom: 10px; }
.huge-data { font-size: 70px; font-weight: 900; color: #d32f2f; }
.huge-loc { font-size: 50px; font-weight: 900; }
.time-data { font-size: 35px; font-weight: 700; color: #004d40; margin-top: 10px; }
.large-data { font-size: 50px; font-weight: 900; color: #1976d2; }
.med-data { font-size: 30px; font-weight: 700; }
.full-screen-map { width: 100%; height: 100vh; border: none; }
.tab-pane { display: none; }
.active { display: block; }
.bottom-nav { position: fixed; bottom: 0; width: 100%; display: flex; background: #004d40; padding: 15px 0; }
.bottom-nav button { flex: 1; border: none; background: none; color: white; font-weight: bold; font-size: 16px; }
