body {
    background-color: #e0f2f1; /* Light Teal Background */
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    margin: 0;
    padding: 20px;
    color: #333;
}

.main-container {
    max-width: 600px;
    margin: 0 auto;
}

header h1 {
    text-align: center;
    color: #00695c; /* Darker Teal */
    font-size: 1.5rem;
    margin-bottom: 20px;
}

.data-card {
    background-color: #ffffff;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 15px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    border-left: 5px solid #00897b;
    text-align: center;
}

.label {
    font-size: 0.9rem;
    color: #555;
    margin-bottom: 5px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.value {
    font-size: 3rem;
    font-weight: bold;
    color: #004d40;
}

.unit {
    font-size: 1rem;
    color: #777;
    display: inline-block;
    margin-left: 5px;
}

.location-card {
    border-left: 5px solid #d32f2f; /* Red accent for location */
}

.location-text {
    font-size: 1.2rem; /* Smaller text for lat/lon */
    color: #333;
    word-wrap: break-word;
}
