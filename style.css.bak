body { background-color: #0f172a; color: #f8fafc; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 20px; }
.app-container { max-width: 500px; margin: 0 auto; }
.app-title { text-align: center; font-size: 24px; font-weight: bold; color: #38bdf8; margin-bottom: 20px; letter-spacing: 2px; }
.card { background: #1e293b; border: 1px solid #334155; padding: 20px; border-radius: 16px; margin-bottom: 15px; text-align: center; }
.label { font-size: 14px; color: #94a3b8; text-transform: uppercase; }
.value { font-size: 50px; font-weight: bold; color: #facc15; }
.value-loc { font-size: 22px; font-weight: 600; color: #fff; margin-top: 10px; }
.unit { font-size: 18px; color: #94a3b8; }
.location-card { border-left: 5px solid #38bdf8; }
