:root { --bg: #0a192f; --card: #112240; --text: #ffffff; --accent: #64ffda; }
.light-mode { --bg: #f4f4f4; --card: #ffffff; --text: #000000; }
body { background: var(--bg); color: var(--text); font-family: sans-serif; height: 100vh; margin:0; }
.tab-pane { display: none; height: 85vh; overflow-y: auto; }
.tab-pane.active { display: block; }
@keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
/* Animation Card */
.animate-card { animation: slideUp 0.5s ease-out; }
@keyframes slideUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
.card { background: var(--card); margin: 15px; padding: 25px; border-radius: 25px; text-align: center; border: 1px solid var(--accent); }
.huge-text { font-size: 42px; font-weight: 900; }
.speed-text { font-size: 48px; font-weight: 900; color: #ff5722; }
.wind-text {font-weight: 700;}
.bottom-nav { position: fixed; bottom: 0; width: 100%; display: flex; background: #004d40; }
.bottom-nav button { flex: 1; padding: 20px; border:none; background:none; color: white; font-size: 24px; }
.input-field { width: 90%; padding: 12px; margin: 10px 0; border-radius: 10px; border: 1px solid #ccc; }
.btn { width: 95%; padding: 15px; margin-top:10px; border-radius: 10px; border: none; background: #00796b; color: white; font-weight: bold; }
