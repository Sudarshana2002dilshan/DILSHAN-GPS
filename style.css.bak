body { background: #020617; color: white; font-family: sans-serif; margin: 0; padding: 10px; }
.tabs { display: flex; gap: 5px; margin-bottom: 20px; }
.tabs button { flex: 1; padding: 12px; background: #1e293b; border: none; color: #94a3b8; border-radius: 8px; font-weight: bold; }
.main-val { font-size: 48px; font-weight: 900; color: #fbbf24; text-align: center; margin: 20px 0; }
.loc-box { background: #0f172a; padding: 25px; border-radius: 20px; text-align: center; border: 1px solid #1e293b; }
.val-big { font-size: 42px; font-weight: 800; color: #fff; line-height: 1.2; }
.sub-box { margin-top: 20px; padding: 15px; text-align: center; color: #38bdf8; font-size: 18px; font-weight: bold; }
.action-btn { width: 100%; padding: 20px; background: #059669; border: none; color: white; border-radius: 10px; font-size: 18px; }
.sos-btn { width: 100%; padding: 30px; background: #dc2626; border: none; color: white; font-size: 24px; font-weight: 900; border-radius: 10px; }
.night-mode { background: #000; color: #ff0000; } /* රතු-කළු නයිට් මෝඩ් */
.main-val { font-size: 50px; font-weight: 900; color: #ff4444; text-align: center; }
.sos-btn { width: 100%; padding: 40px; background: #800000; color: #fff; border: 2px solid red; font-size: 25px; }
.tabs button { background: #222; color: #fff; padding: 15px; border: 1px solid #444; }

