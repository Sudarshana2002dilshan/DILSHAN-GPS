:root { --bg-dark: #0a192f; --card-dark: #112240; --accent: #64ffda; }
body { margin: 0; font-family: sans-serif; background: var(--bg-dark); color: #fff; }
.tab-pane { display: none; padding-bottom: 80px; }
.active { display: block; }
.logo-container { display: flex; justify-content: center; padding: 20px; }
.main-logo { width: 120px; height: 120px; border-radius: 50%; border: 4px solid var(--accent); }
.card { background: var(--card-dark); border: 2px solid var(--accent); margin: 15px; padding: 25px; border-radius: 25px; text-align: center; }
.huge-text { font-size: 35px; font-weight: 900; color: var(--accent); margin: 5px 0; }
.alert-box { background: #ff4444; color: white; padding: 15px; border-radius: 15px; margin: 15px; font-weight: bold; text-align: center; }
.bottom-nav { position: fixed; bottom: 0; width: 100%; display: flex; background: #004d40; border-top: 3px solid var(--accent); }
.bottom-nav button { flex: 1; padding: 18px; border: none; background: none; color: white; font-weight: bold; cursor: pointer; }
iframe { width: 100%; height: 100vh; border: none; }
.btn { width: 100%; padding: 15px; background: #004d40; color: white; border-radius: 12px; border: none; font-weight: bold; }
.btn-wa { display: block; padding: 15px; background: #25D366; color: white; border-radius: 12px; margin-top: 15px; text-align: center; text-decoration: none; font-weight: bold; }
